# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# LLM providers (at least one required)
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=

# Optional local fallback
OLLAMA_BASE_URL=http://localhost:11434

# Storage
CHROMA_PERSIST_DIR=/tmp/0xautopr/chroma
AUTOXPR_WORK_DIR=/tmp/0xautopr

# Server
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# Set to true to skip pushing fix PRs
DRY_RUN=false

# Set to true when LLM rate limits hit — uses rule-based review/fix only
HEURISTICS_ONLY=false
